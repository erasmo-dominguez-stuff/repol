# Integration environment
# Copy this to .env and fill in the values
#
# 1. Create a smee channel: npx smee --url https://smee.io/new
#    or visit https://smee.io/new in a browser
SMEE_URL=https://smee.io/YOUR_CHANNEL_ID

# Authentication — choose ONE method:
#
# Option A: GitHub App (recommended)
#   Create a GitHub App with deployment_protection_rule permissions.
#   Download the private key (.pem) and set the path below.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_FILE=./app.pem

# Option B: Personal Access Token
#   Create a token with repo scope (classic) or actions:write (fine-grained)
GITHUB_TOKEN=

# 3. (Optional) Override the policy directory
# REPOL_DIR=/repol
